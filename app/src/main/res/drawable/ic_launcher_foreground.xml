<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Group to center within 66dp safe zone (inside 108dp base canvas) -->
    <group
        android:translateX="0"
        android:translateY="0">

        <!-- Outer pulsing soundwave left -->
        <path
            android:pathData="M 32,44 C 29,48 29,56 32,60"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="32"
                    android:startY="44"
                    android:endX="32"
                    android:endY="60">
                    <item android:color="#C084FC" android:offset="0.0" />
                    <item android:color="#6366F1" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Inner soundwave left -->
        <path
            android:pathData="M 38,40 C 34,46 34,58 38,64"
            android:strokeWidth="3.5"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="38"
                    android:startY="40"
                    android:endX="38"
                    android:endY="64">
                    <item android:color="#FFFFFF" android:offset="0.0" />
                    <item android:color="#818CF8" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Microphone Main Capsule -->
        <path
            android:pathData="M 46,32 C 46,27.5 49.5,24 54,24 C 58.5,24 62,27.5 62,32 L 62,52 C 62,56.5 58.5,60 54,60 C 49.5,60 46,56.5 46,52 Z"
            android:fillColor="#FFFFFF" />

        <!-- Microphone Grille detail line -->
        <path
            android:pathData="M 46,40 L 62,40"
            android:strokeColor="#E2E8F0"
            android:strokeWidth="1.5" />
        <path
            android:pathData="M 46,44 L 62,44"
            android:strokeColor="#E2E8F0"
            android:strokeWidth="1.5" />

        <!-- Microphone Outer Rim / Cradle Support -->
        <path
            android:pathData="M 40,48 C 40,58 48,66 54,66 C 60,66 68,58 68,48"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="40"
                    android:startY="48"
                    android:endX="68"
                    android:endY="66">
                    <item android:color="#C084FC" android:offset="0.0" />
                    <item android:color="#6366F1" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Microphone Stand Stem -->
        <path
            android:pathData="M 54,66 L 54,78"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="54"
                    android:startY="66"
                    android:endX="54"
                    android:endY="78">
                    <item android:color="#6366F1" android:offset="0.0" />
                    <item android:color="#10B981" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Microphone Stand Base -->
        <path
            android:pathData="M 44,78 L 64,78"
            android:strokeWidth="4"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="44"
                    android:startY="78"
                    android:endX="64"
                    android:endY="78">
                    <item android:color="#10B981" android:offset="0.0" />
                    <item android:color="#059669" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Inner soundwave right -->
        <path
            android:pathData="M 70,40 C 74,46 74,58 70,64"
            android:strokeWidth="3.5"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="70"
                    android:startY="40"
                    android:endX="70"
                    android:endY="64">
                    <item android:color="#FFFFFF" android:offset="0.0" />
                    <item android:color="#818CF8" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Outer pulsing soundwave right -->
        <path
            android:pathData="M 76,44 C 79,48 79,56 76,60"
            android:strokeWidth="3"
            android:strokeLineCap="round"
            android:fillColor="#00000000">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:type="linear"
                    android:startX="76"
                    android:startY="44"
                    android:endX="76"
                    android:endY="60">
                    <item android:color="#C084FC" android:offset="0.0" />
                    <item android:color="#6366F1" android:offset="1.0" />
                </gradient>
            </aapt:attr>
        </path>

    </group>
</vector>
